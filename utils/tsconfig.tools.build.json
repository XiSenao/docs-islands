{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools build leaf for package build/config files; depends on library build leaves.
  "extends": [
    "./tsconfig.graph.paths.generated.json",
    "./tsconfig.json",
    "../tsconfig.graph.base.json"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tools.tsbuildinfo",
    "isolatedDeclarations": false,
    "lib": ["ES2023"]
  },
  "references": [
    {
      "path": "./tsconfig.lib.build.json"
    }
  ],
  "include": ["rolldown.config.ts"]
}
