{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Library build leaf. Keep tooling, tests, docs, playground, and smoke files out.
  "extends": "../tsconfig.graph.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "references": [
    {
      "path": "../packages/logger/tsconfig.lib.build.json"
    }
  ],
  "include": ["*.ts", "bin/**/*.ts"],
  "exclude": [
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache",
    "eslint.config.mjs",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
