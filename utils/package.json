{
  "name": "@docs-islands/utils",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Shared runtime and build utilities for docs-islands packages",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "link-guard": "./bin/link-guard-stub.mjs"
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "del-cli .eslintcache dist node_modules"
  },
  "dependencies": {
    "@docs-islands/logger": "catalog:prod",
    "tinyglobby": "catalog:prod"
  },
  "devDependencies": {
    "eslint": "catalog:lint",
    "@types/picomatch": "catalog:dev",
    "@docs-islands/eslint-config": "workspace:*",
    "typescript": "catalog:dev",
    "pathe": "catalog:dev",
    "is-in-ci": "catalog:dev",
    "zod": "catalog:dev",
    "del-cli": "catalog:dev",
    "vite": "catalog:prod",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "vitest": "catalog:test"
  },
  "exports": {
    "./builtin": "./dist/builtin.js",
    "./dom-iterable": "./dist/dom-iterable.js",
    "./env": "./dist/env.js",
    "./fs-utils": "./dist/fs-utils.js",
    "./general": "./dist/general.js",
    "./logger": "./dist/logger.js",
    "./path": "./dist/path.js",
    "./package.json": "./package.json"
  },
  "sideEffects": false
}
