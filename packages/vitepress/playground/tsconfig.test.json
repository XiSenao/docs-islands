{
  // Playground-local test check. Build leaf: tsconfig.test.build.json.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "client.d.ts",
    "test-utils/**/*.ts",
    "**/*.spec.ts",
    "vitest.config.ts",
    "vitestGlobalSetup.ts",
    "vitestSetup.ts"
  ]
}
