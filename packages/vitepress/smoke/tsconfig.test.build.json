{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Smoke test build leaf. Tests must not be referenced by source/runtime projects.
  "extends": [
    "./tsconfig.graph.paths.generated.json",
    "./tsconfig.test.json",
    "../../../tsconfig.graph.base.json"
  ],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/test.tsbuildinfo"
  },
  "references": [
    {
      "path": "./tsconfig.source.build.json"
    },
    {
      "path": "../tsconfig.tools.build.json"
    },
    {
      "path": "../../../utils/tsconfig.lib.build.json"
    }
  ]
}
