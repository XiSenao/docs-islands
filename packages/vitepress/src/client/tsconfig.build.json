{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Client runtime build leaf; keep Node ambient types out.
  "extends": ["./tsconfig.json", "../../../../tsconfig.graph.base.json"],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "isolatedDeclarations": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    "jsx": "preserve"
  },
  "references": [
    {
      "path": "../shared/tsconfig.build.json"
    },
    {
      "path": "../../../logger/tsconfig.lib.build.json"
    },
    {
      "path": "../../../../utils/tsconfig.lib.build.json"
    },
    {
      "path": "../../../core/tsconfig.lib.build.json"
    }
  ],
  "include": ["./**/*.ts", "./**/*.tsx", "./**/*.d.ts", "../types/**/*.d.ts"],
  "exclude": [
    ".tsbuild",
    "**/.tsbuild/**",
    "dist",
    "cache",
    "coverage",
    "node_modules",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
