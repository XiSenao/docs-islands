{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools build leaf for VitePress build/config files; runtime source stays in src/* build leaves.
  "extends": [
    "./tsconfig.tools.json",
    "../../tsconfig.graph.base.json"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tools.tsbuildinfo"
  },
  "references": [
    {
      "path": "./src/shared/tsconfig.build.json"
    },
    {
      "path": "./src/node/tsconfig.build.json"
    },
    {
      "path": "./src/client/tsconfig.build.json"
    },
    {
      "path": "../../packages/logger/tsconfig.lib.build.json"
    },
    {
      "path": "../../utils/tsconfig.lib.build.json"
    }
  ]
}
