{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Library build leaf. Keep logger tooling out to avoid logger/tools cycles.
  "extends": "../../tsconfig.graph.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "lib": ["ESNext", "DOM"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
