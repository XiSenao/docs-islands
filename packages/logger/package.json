{
  "name": "@docs-islands/logger",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Shared runtime logger and compile-time pruning plugin for docs-islands packages",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiSenao/docs-islands.git",
    "directory": "packages/logger"
  },
  "bugs": {
    "url": "https://github.com/XiSenao/docs-islands/issues"
  },
  "homepage": "https://docs.senao.me/docs-islands",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache --cache-location ./node_modules/.cache/eslint/",
    "lint:package": "tsx scripts/lint-package.ts",
    "lint:package:publint": "tsx scripts/lint-package.ts --tool publint",
    "lint:package:attw": "tsx scripts/lint-package.ts --tool attw",
    "lint:package:boundary": "tsx scripts/lint-package.ts --tool boundary",
    "typecheck": "tsc --noEmit",
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "changelog": "tsx ../../scripts/changelog.ts --package logger",
    "changelog:preview": "tsx ../../scripts/changelog.ts --package logger --dry-run",
    "release": "tsx ../../scripts/release.ts --package logger",
    "release:patch": "tsx ../../scripts/release.ts --package logger --type patch",
    "release:minor": "tsx ../../scripts/release.ts --package logger --type minor",
    "release:major": "tsx ../../scripts/release.ts --package logger --type major",
    "release:beta": "tsx ../../scripts/release.ts --package logger --type prerelease --preid beta",
    "release:alpha": "tsx ../../scripts/release.ts --package logger --type prerelease --preid alpha",
    "release:dry": "tsx ../../scripts/release.ts --package logger --type patch --dry-run",
    "test": "vitest run",
    "clean": "del-cli .eslintcache dist coverage node_modules"
  },
  "dependencies": {
    "@babel/parser": "catalog:dev",
    "@babel/traverse": "catalog:dev",
    "@babel/types": "catalog:dev",
    "es-module-lexer": "catalog:dev",
    "magic-string": "catalog:dev",
    "picocolors": "catalog:dev",
    "picomatch": "catalog:prod",
    "unplugin": "catalog:prod"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:lint",
    "@docs-islands/eslint-config": "workspace:*",
    "@rollup/plugin-replace": "catalog:dev",
    "@publint/pack": "catalog:lint",
    "@types/babel__traverse": "catalog:dev",
    "@types/node": "catalog:dev",
    "@docs-islands/utils": "workspace:*",
    "del-cli": "catalog:dev",
    "eslint": "catalog:lint",
    "jsdom": "catalog:test",
    "publint": "catalog:lint",
    "rollup": "catalog:dev",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:test"
  },
  "peerDependencies": {
    "@rollup/plugin-replace": "catalog:dev",
    "rolldown": "catalog:dev"
  },
  "peerDependenciesMeta": {
    "@rollup/plugin-replace": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./internal": {
      "types": "./src/internal.ts",
      "import": "./src/internal.ts"
    },
    "./runtime": {
      "types": "./src/runtime.ts",
      "import": "./src/runtime.ts"
    },
    "./plugin": {
      "types": "./src/plugin/index.ts",
      "import": "./src/plugin/index.ts"
    },
    "./internal-helper/internal": "./dist/internal.js",
    "./internal-helper/runtime": "./dist/runtime.js",
    "./package.json": "./package.json"
  },
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "internal": [
        "./internal.d.ts"
      ],
      "plugin": [
        "./plugin/index.d.ts"
      ],
      "runtime": [
        "./runtime.d.ts"
      ],
      "internal-helper/internal": [
        "./internal.d.ts"
      ],
      "internal-helper/runtime": [
        "./runtime.d.ts"
      ]
    }
  },
  "sideEffects": false
}
