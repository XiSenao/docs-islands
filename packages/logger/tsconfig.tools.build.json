{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools build leaf. This is where logger may depend on plugin-license.
  "extends": "../../tsconfig.graph.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "isolatedDeclarations": false,
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "references": [
    {
      "path": "./tsconfig.lib.build.json"
    },
    {
      "path": "../../utils/tsconfig.lib.build.json"
    },
    {
      "path": "../../packages/plugins/license/tsconfig.lib.build.json"
    }
  ],
  "include": [
    "package.json",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "src",
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
