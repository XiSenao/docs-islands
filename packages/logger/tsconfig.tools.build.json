{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools build leaf. It must be split from lib, otherwise it will cause an error due to circular dependency.
  "extends": [
    "./tsconfig.graph.paths.generated.json",
    "./tsconfig.json",
    "../../tsconfig.graph.base.json"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tools.tsbuildinfo",
    "lib": ["ES2023"]
  },
  "references": [
    {
      "path": "./tsconfig.lib.build.json"
    },
    {
      "path": "../../utils/tsconfig.lib.build.json"
    },
    {
      "path": "../../packages/plugins/license/tsconfig.lib.build.json"
    }
  ],
  "include": [
    "package.json",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts/**/*.ts"
  ]
}
