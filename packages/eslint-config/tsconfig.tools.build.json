{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools build leaf for package build/config files.
  "extends": [
    "./tsconfig.graph.paths.generated.json",
    "./tsconfig.json",
    "../../tsconfig.graph.base.json"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tools.tsbuildinfo",
    "isolatedDeclarations": false,
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "references": [
    {
      "path": "./tsconfig.lib.build.json"
    },
    {
      "path": "../../utils/tsconfig.lib.build.json"
    }
  ],
  "exclude": [
    "src",
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
