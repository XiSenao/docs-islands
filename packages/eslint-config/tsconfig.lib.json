{
  // Package-local library check. Build leaf: tsconfig.lib.build.json.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023"]
  },
  "exclude": [
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
