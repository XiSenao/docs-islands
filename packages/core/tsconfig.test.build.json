{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Test build leaf for core unit tests and test helpers.
  "extends": "../../tsconfig.graph.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "isolatedDeclarations": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals"],
    "jsx": "preserve"
  },
  "references": [
    {
      "path": "./tsconfig.lib.build.json"
    },
    {
      "path": "../logger/tsconfig.lib.build.json"
    },
    {
      "path": "../../utils/tsconfig.lib.build.json"
    }
  ],
  "include": [
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "tests/**/*.ts",
    "**/types/**/*.d.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache"
  ]
}
