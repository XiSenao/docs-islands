{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Test build leaf for core unit tests and test helpers.
  "extends": [
    "./tsconfig.graph.paths.generated.json",
    "./tsconfig.test.json",
    "../../tsconfig.graph.base.json"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/test.tsbuildinfo",
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "references": [
    {
      "path": "./tsconfig.lib.build.json"
    },
    {
      "path": "../../utils/tsconfig.lib.build.json"
    }
  ],
  "include": [
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
