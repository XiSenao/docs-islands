{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Library build leaf for plugin runtime source; tooling stays in tsconfig.tools.build.json.
  "extends": "../../../tsconfig.graph.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "lib": ["ES2023"],
    "types": ["node"],
  },
  "references": [
    {
      "path": "../../../packages/logger/tsconfig.lib.build.json",
    },
    {
      "path": "../../../utils/tsconfig.lib.build.json",
    },
  ],
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "cache",
    "**/*cache*/**",
    "coverage",
    "node_modules",
    ".eslintcache",
    "eslint.config.mjs",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts",
  ],
}
