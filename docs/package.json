{
  "name": "@docs-islands/monorepo-docs",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "pnpm clean:remaining && del-cli .eslintcache .vitepress/cache .vitepress/dist node_modules",
    "clean:remaining": "del-cli .vitepress/config.ts.timestamp-*.mjs || true"
  },
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "vue": "catalog:prod"
  },
  "devDependencies": {
    "@types/http-proxy": "catalog:docs-dev",
    "eslint": "catalog:lint",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/vitepress": "workspace:*",
    "typescript": "catalog:dev",
    "vue-tsc": "catalog:dev",
    "http-proxy": "catalog:docs-dev",
    "@docs-islands/utils": "workspace:*",
    "vitepress": "catalog:frameworks",
    "vitepress-plugin-group-icons": "catalog:docs-dev",
    "vitepress-plugin-llms": "catalog:docs-dev",
    "@nolebase/vitepress-plugin-enhanced-mark": "catalog:docs-dev",
    "@vercel/analytics": "catalog:docs-dev",
    "del-cli": "catalog:dev",
    "vue-router": "catalog:dev"
  }
}
